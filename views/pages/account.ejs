<%- include('../partials/head') %>
<script>
  window.__themeLightLabel = '<%= t("theme.light") %>';
  window.__themeDarkLabel = '<%= t("theme.dark") %>';
</script>
<%- include('../partials/nav-public') %>

<h1 class="h3 mb-3"><%= t('account.title') %></h1>
<p class="lead"><%= t('account.lead') %></p>
<div class="card fan-card shadow-sm border-0" style="max-width: 28rem;">
  <div class="card-body">
    <p class="mb-1"><strong><%= t('signup.name') %>:</strong> <%= user.name %></p>
    <p class="mb-1"><strong><%= t('login.email') %>:</strong> <%= user.email %></p>
    <p class="mb-0 small text-muted"><%= t('account.since') %> <%= user.created_at %></p>
  </div>
</div>

<%- include('../partials/footer') %>
