<%- include('../partials/head') %>
<script>
  window.__themeLightLabel = '<%= t("theme.light") %>';
  window.__themeDarkLabel = '<%= t("theme.dark") %>';
</script>
<%- include('../partials/nav-public') %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <h1 class="h3 mb-2"><%= t('nav.signup') %></h1>
    <p class="small text-muted mb-4"><%= t('signup.note') %></p>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form method="post" action="/inregistrare" class="card shadow-sm fan-card border-0">
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label" for="name"><%= t('signup.name') %></label>
          <input class="form-control" type="text" name="name" id="name" required maxlength="120">
        </div>
        <div class="mb-3">
          <label class="form-label" for="email"><%= t('login.email') %></label>
          <input class="form-control" type="email" name="email" id="email" required autocomplete="email">
        </div>
        <div class="mb-3">
          <label class="form-label" for="password"><%= t('login.password') %></label>
          <input class="form-control" type="password" name="password" id="password" required minlength="6" autocomplete="new-password">
        </div>
        <div class="mb-3">
          <label class="form-label" for="password2"><%= t('login.password') %> (2)</label>
          <input class="form-control" type="password" name="password2" id="password2" required minlength="6" autocomplete="new-password">
        </div>
        <button class="btn btn-neon w-100" type="submit"><%= t('signup.submit') %></button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
