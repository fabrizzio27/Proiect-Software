<%- include('../partials/head') %>
<script>
  window.__themeLightLabel = '<%= t("theme.light") %>';
  window.__themeDarkLabel = '<%= t("theme.dark") %>';
</script>
<%- include('../partials/nav-public') %>

<h1 class="mb-4 hero-title"><%= t('blog.title') %></h1>
<% if (!posts.length) { %>
  <p class="text-body-secondary"><%= t('blog.empty') %></p>
<% } else { %>
  <div class="row row-cols-1 row-cols-md-2 g-4">
    <% posts.forEach(function (p) { %>
      <div class="col">
        <article class="card h-100 glass-card border-0 rounded-4 overflow-hidden">
          <% if (p.image_url) { %>
            <img src="<%= p.image_url %>" class="card-img-top card-img-fixed" alt="">
          <% } %>
          <div class="card-body d-flex flex-column">
            <h2 class="h5 card-title hero-title" style="font-size:1.1rem"><%= p.title %></h2>
            <p class="card-text text-body-secondary small flex-grow-1"><%= p.excerpt || '' %></p>
            <a class="btn btn-neon btn-sm mt-auto align-self-start" href="/blog/<%= p.slug %>"><%= t('blog.readMore') %></a>
          </div>
          <div class="card-footer small text-body-secondary border-top border-secondary"><%= p.created_at %></div>
        </article>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/footer') %>
