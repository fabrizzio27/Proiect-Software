<%- include('../partials/head') %>
<script>
  window.__themeLightLabel = '<%= t("theme.light") %>';
  window.__themeDarkLabel = '<%= t("theme.dark") %>';
</script>
<%- include('../partials/nav-public') %>

<h1 class="mb-2 hero-title"><%= t('gallery.title') %></h1>
<p class="text-body-secondary mb-4"><%= t('gallery.carouselIntro') %></p>

<div id="playerCarousel" class="carousel slide carousel-futuristic" data-bs-ride="carousel">
  <div class="carousel-indicators">
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="1"></button>
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="1" aria-label="2"></button>
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="2" aria-label="3"></button>
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="3" aria-label="4"></button>
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="4" aria-label="5"></button>
    <button type="button" data-bs-target="#playerCarousel" data-bs-slide-to="5" aria-label="6"></button>
  </div>
  <div class="carousel-inner rounded-4 overflow-hidden shadow-neon">
    <div class="carousel-item active">
      <img src="https://images.unsplash.com/photo-1574629810360-7efbbe195018?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.messi') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.messi') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">#10</span>
      </div>
    </div>
    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1431324155629-1a6deb1dec8d?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.ronaldo') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.ronaldo') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">CR7</span>
      </div>
    </div>
    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1522778119026-d647f0596c20?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.mbappe') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.mbappe') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">FR</span>
      </div>
    </div>
    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1517466787929-bc90951d0974?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.haaland') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.haaland') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">#9</span>
      </div>
    </div>
    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1508098682722-e99c43a406b2?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.neymar') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.neymar') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">BR</span>
      </div>
    </div>
    <div class="carousel-item">
      <img src="https://images.unsplash.com/photo-1560272564-c83b66d1d192?w=1200" class="d-block w-100 carousel-hero-img" alt="<%= t('gallery.modric') %>">
      <div class="carousel-caption glass-caption text-start">
        <h2 class="h3 mb-1"><%= t('gallery.modric') %></h2>
        <span class="badge rounded-pill bg-neon text-dark fw-semibold">HR</span>
      </div>
    </div>
  </div>
  <button class="carousel-control-prev ball-control" type="button" data-bs-target="#playerCarousel" data-bs-slide="prev">
    <span class="ball-control-inner" aria-hidden="true"><span class="ball-emoji">⚽</span><span class="ball-chev ball-chev-prev">&lsaquo;</span></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next ball-control" type="button" data-bs-target="#playerCarousel" data-bs-slide="next">
    <span class="ball-control-inner" aria-hidden="true"><span class="ball-emoji">⚽</span><span class="ball-chev ball-chev-next">&rsaquo;</span></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>

<%- include('../partials/footer') %>
